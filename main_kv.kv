#: import SlideTransition kivy.uix.screenmanager.SlideTransition
#: import sys sys
<Button_main@MDButton>
#    on_release: root.parent.parent.parent.choice_button(self)
    theme_bg_color: "Custom"
    # theme_color: "Custom"
    md_bg_color: .1,.1,.1, 1
    style: "outlined"
    radius:5
    # md_bg_color: "red"
    # md_bg_color: "green"
    # style: "elevated" 'md_bg_color_disabled' 'on_md_bg_color'
    # style: "filled"
    # style: "tonal"
    # style: "text"
    # pos_hint: {"bottom": 1}
    theme_width: "Custom"
    theme_height: "Custom"
    size_hint: (1,.9)

<Button_text@MDButtonText>
    pos_hint: {"center_x": 1,"center_y": 1}
    theme_text_color: "Custom"
    text_color: "white"
    theme_font_size: "Custom"
    font_size: sp(20)

<TimeBox@MDBoxLayout>
    orientation: "vertical"
    padding: 5
    canvas.before:
        Color:
            rgba: 0,0,0,1
        Line:
            width:1
            rectangle: self.x,self.y,self.width,self.height
<TimeSpinner@Spinner>
    font_size: sp(30)

<TitleLabel@MDLabel>
    markup: True
    size_hint: 1, 1
    # font_size: 30
    #color: 0,0,0
    font_style: "Title"
    role: "small"
    bold: True
    text_size: self.size
    halign: "center"
    valign: "center"

<Page_main>:
    id: page_main
    name: "main_page"
    md_bg_color: app.theme_cls.primaryContainerColor # app.theme_cls.primaryColor # app.theme_cls.primaryContainerColor
    MDBoxLayout:
        id: root_main_box
        orientation: "vertical"
        size: root.size
        MDBoxLayout:
            id: TOP_box
            padding: [sp(10),sp(10),sp(10),0]
            size_hint_y: .8
            MDBoxLayout:
                id:left_box
                orientation: "vertical"
                MDBoxLayout:
                    size_hint_y: .2
                    padding: [0,0,sp(5),sp(5)]
                    orientation: "vertical"
                    MDBoxLayout:
                        size_hint_y: .6
                        TitleLabel:
                            text: "Дата"
                        TimeSpinner:
                            id: spinner_day
                            text: root.day_spinner
                            values: map(str,list(range(1,32)))
                    MDBoxLayout:
                        size_hint_y: .4
                        TimeSpinner:
                            id: spinner_month
                            text:  root.month_spinner_str
                            values: root.month_spinner_lst
                            font_size: 30
                TimeBox:
                    size_hint_y: .2
                    MDBoxLayout:
                        id: lunch_time_box
                        size_hint: 1,1
                        TitleLabel:
                            text: "    установите \n[color=#4682B4]НАЧАЛО перерыва[/color]"
                    MDBoxLayout:
                        MDBoxLayout:
                            HoursTextInput:
                                parent_color: app.theme_cls.primaryContainerColor
                                id: hoursstartlunch
                                size_hint_y: 1
                                on_text: root.calculation_of_working()
                        TitleLabel:
                            size_hint: .1, 1
                            text: ":"
                        MDBoxLayout:
                            MinutesTextInput:
                                parent_color: app.theme_cls.primaryContainerColor
                                id: minutesstartlunch
                                size_hint_y: 1
                                on_text: root.calculation_of_working()

                TimeBox:
                    size_hint_y: .2
                    MDBoxLayout:
                        orientation: "vertical"

                        MDBoxLayout:
                            TitleLabel:
                                text: "установите\n  [color=#4682B4]КОНЕЦ перерыва[/color]"
                    MDBoxLayout:
                        MDBoxLayout:
                            HoursTextInput:
                                parent_color: app.theme_cls.primaryContainerColor
                                id: hoursendlunch
                                size_hint_y: 1
                                on_text: root.calculation_of_working()

                        TitleLabel:
                            size_hint: .1, 1
                            text: ":"
                        MDBoxLayout:
                            MinutesTextInput:
                                parent_color: app.theme_cls.primaryContainerColor
                                id: minutesendlunch
                                size_hint_y: 1
                                on_text: root.calculation_of_working()

                TimeBox:
                    size_hint_y: .3
                    MDBoxLayout:
                        size_hint_y: .15
                        TitleLabel:
                            id: root.date_a_day
                            text: root.date_total_time
                            role: "large"
                    MDBoxLayout:
                        size_hint_y: .15
                        TitleLabel:
                            id: savingtext
                            text: root.lab_save_txt
                            role: "large"
                            halign: "center"
                    MDBoxLayout:
                        size_hint_y: .25
                        TitleLabel:
                            size_hint_x: .5
                            text: root.total_hours_work
                            font_style: "Headline"
                            role: "large"
                        TitleLabel:
                            text: "часов"
                            bold: False
                            halign: "left"

                    MDBoxLayout:
                        size_hint_y: .25
                        TitleLabel:
                            text: root.total_minutes_work
                            font_style: "Headline"
                            role: "large"
                            halign: "right"
                        TitleLabel:
                            size_hint_x: .5
                            text: "мин."
                            bold: False



            MDBoxLayout:
                id: right_box
                orientation: "vertical"

                TimeBox:
                    padding: 5
                    MDBoxLayout:
                        TitleLabel:
                            text: "  [color=#4682B4]НАЧАЛО[/color]\n рабочего дня"
                    MDBoxLayout:
                        MDBoxLayout:
                            HoursTextInput:
                                parent_color: app.theme_cls.primaryContainerColor
                                id: startworkhours
                                size_hint_y: 1
                                on_text: root.calculation_of_working()
                        TitleLabel:
                            size_hint: .1, 1
                            text: ":"
                        MDBoxLayout:
                            MinutesTextInput:
                                parent_color: app.theme_cls.primaryContainerColor
                                id: startworkminutes
                                size_hint_y: 1
                                on_text: root.calculation_of_working()



                TimeBox:
                    padding: 5
                    orientation: "vertical"
                    MDBoxLayout:
                        id: box_time_end
                        TitleLabel:
                            text: "   [color=#4682B4]КОНЕЦ[/color]\n    рабочего дня"
                    MDBoxLayout:
                        MDBoxLayout:
                            HoursTextInput:
                                parent_color: app.theme_cls.primaryContainerColor
                                id: hoursendwork
                                size_hint_y: 1
                                on_text: root.calculation_of_working()
                        TitleLabel:
                            size_hint: .1, 1
                            text: ":"

                        MDBoxLayout:
                            MinutesTextInput:
                                parent_color: app.theme_cls.primaryContainerColor
                                id: minutesendwork
                                size_hint_y: 1
                                on_text: root.calculation_of_working()

                TimeBox:
                    padding: 5
                    spacing: 10
                    orientation: "vertical"
                    MDBoxLayout:
                        Button_main:
                            on_release: root.show_DICT()
#                                root.manager.transition = SlideTransition()
#                                root.manager.transition.direction = "left"
#                                root.manager.current = "stat_page"
                            Button_text:
                                # text_size: self.size
                                pos_hint: {"center_x": .5,"center_y": .5}
                                text: "Статистика"
#                                halign: "center"
#                                valign: "center"

                    MDBoxLayout:
                        orientation: "vertical"
                        size_hint:1,1
                        Button_main:
                            on_release: root.create_route_kart()
                            Button_text:
                                pos_hint: {"center_x": .5,"center_y": .5}
                                # text_size: self.size
                                text: "Создать\nмаршрут"
                                halign: "center"
                                valign: "center"

                MDBoxLayout:
                    TimeBox:
                        size_hint_x: .7
                        orientation: "vertical"
                        MDBoxLayout:
                            RouteTextInput:
                                parent_color: app.theme_cls.primaryContainerColor
                                id: route_number_textinput
                                mode: "outlined"
                                multiline: False
                                on_text: root.search_rout_in_dict()


                        MDBoxLayout:
                            KartaTextInput:
                                parent_color: app.theme_cls.primaryContainerColor
                                id: karta_route_number_textinput
                                mode: "outlined"
                                multiline: False
                                on_text: root.search_rout_in_dict()

                    TimeBox:
                        size_hint_x: .3
                        ToggleButton:
                            id:sm_1
                            text: "1"
                            group:'smena'
                            state:'down'
                        ToggleButton:
                            id:sm_2
                            text: "2"
                            group:'smena'



        MDBoxLayout:
            id: BOTTOM_box
            padding: [sp(10),sp(10),sp(10),0]
            orientation: "vertical"
            size_hint_y: .15
            MDBoxLayout:
                size_hint_y: .40
                padding:[0,0,0,sp(5)]
                MDBoxLayout:
                    padding:[0,0,sp(10),0]
                    Button_main:
                        id: save_button
                        on_release: root.intercept_data_main_screen()
                        md_bg_color: app.theme_cls.primaryContainerColor if self.disabled else "black"
                        disabled: True
                        Button_text:
                            pos_hint: {"center_x": .5,"center_y": .5}
                            role:"small"
                            text: "Сохранить"
                            valign: "center"
                MDBoxLayout:
                    Button_main:
                        on_release: sys.exit()
                        md_bg_color: "black"
                        Button_text:
                            pos_hint: {"right": .7,"center_y": .5}
                            text: "Выход"
            MDBoxLayout:
                size_hint:(1,.1)
                # padding: sp(5)
                TitleLabel:
                    markup: True
                    text: "автор: Погодаев Илья Сергеевич [color=#0B0080][b]ilya1880@mail.ru[/b][/color]"
                    theme_font_size: "Custom"
                    font_size: sp(11)
                    halign: "center"
                    valign: "center"









