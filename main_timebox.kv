<TimeLabel@MDLabel>
    markup: True
    size_hint: 1, 1
    # font_size: 30
    color: 1,1,1
    font_style: "Title"
    role: "small"
    bold: True
    text_size: self.size
    halign: "center"
    valign: "center"


<Timebox_main>:
    size_hint: 1,1
    MDBoxLayout:
        size_hint_y: 1
        MDBoxLayout:
            md_bg_color: 1,0,0,.5
            size_hint: .4,1
            orientation: "vertical"
            MDBoxLayout:

                TimeLabel:
                    text: f"1   {5}:{10} - {15}:{10}"
            MDBoxLayout:
                TimeLabel:
                    text: f"2   {15}:{10} - {1}:{10}"
        MDBoxLayout:
            size_hint_x: .2
            TimeLabel:
                text: "1"
                role: "large"
        MDBoxLayout:
            md_bg_color: 0,0,1,.5
            size_hint_x: .4
            orientation: "vertical"
            MDBoxLayout:
                TimeLabel:
                    text: f"1   {5}:{20} - {15}:{20}"
            MDBoxLayout:
                TimeLabel:
                    text: f"2   {15}:{20} - {1}:{20}"

    MDDivider:
        size_hint_x: 1
        theme_divider_color: "Custom"
        color: 1,1,1
    MDBoxLayout:
        size_hint_y: .9









