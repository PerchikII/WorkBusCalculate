<TimeLabel@MDLabel>
    markup: True
    size_hint: 1, 1
    # font_size: 30
    color: 1,1,1
    font_style: "Title"
    role: "small"
    bold: True
    text_size: self.size
    halign: "center"
    valign: "center"


<Timebox_main>:
    # size_hint: 1,1
    MDBoxLayout:
        size_hint: 1,1
        MDBoxLayout:
            md_bg_color: 1,0,0,.5
            size_hint: .4,1
            orientation: "vertical"
            MDBoxLayout:
                TimeLabel:
                    size_hint_x: .1
                    text: "1"
                TimeLabel:
                    text: f"{root.start_hours_day_1sm}:{root.start_minutes_day_1sm} - {root.finish_hours_day_1sm}:{root.finish_minutes_day_1sm}"
            MDBoxLayout:
                TimeLabel:
                    size_hint_x: .1
                    text: "2"
                TimeLabel:
                    text: f"{root.start_hours_day_2sm}:{root.start_minutes_day_2sm} - {root.finish_hours_day_2sm}:{root.finish_minutes_day_2sm}"
        MDBoxLayout:
            size_hint_x: .2
            TimeLabel:
                text: root.num_karta
                role: "large"
        MDBoxLayout:
            md_bg_color: 0,0,1,.5
            size_hint_x: .4
            orientation: "vertical"
            MDBoxLayout:
                TimeLabel:
                    size_hint_x: .1
                    text: "1"
                TimeLabel:
                    text: f"{root.start_hours_end_1sm}:{root.start_minutes_end_1sm} - {root.finish_hours_end_1sm}:{root.finish_minutes_end_1sm}"
            MDBoxLayout:
                TimeLabel:
                    size_hint_x: .1
                    text: "2"
                TimeLabel:
                    text: f"{root.start_hours_end_2sm}:{root.start_minutes_end_2sm} - {root.finish_hours_end_2sm}:{root.finish_minutes_end_2sm}"

    MDDivider:
        size_hint_x: 1
        theme_divider_color: "Custom"
        color: 1,1,1
#    MDBoxLayout:
#        size_hint_y: .9









