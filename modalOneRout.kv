<ModalViewOneRout>:
    MDBoxLayout:
        size_hint: 1,1
        md_bg_color: "black"
        orientation: "vertical"
        MDBoxLayout:
            size_hint: 1,.07
            MDBoxLayout:
                md_bg_color: 1,0,0,.5
                TitleLabel:
                    text: "Будние"
                    color: "white"
            MDBoxLayout:
                md_bg_color: "green"
                TitleLabel:
                    font_style: "Display"
                    role: "small"
                    text: root.num_rout
                    color: "white"
                    valign: "top" # ?????????????????????????????????????????
            MDBoxLayout:
                md_bg_color: "blue"
                TitleLabel:
                    text: "Выходные"
                    color: "white"
        MDDivider:
            size_hint_x: 1
            theme_divider_color: "Custom"
            color: 1,1,1

        MDBoxLayout:
            size_hint: 1,.9
            orientation: "vertical"
            Grid_for_One_rout:
                id: main_box_time
                row_force_default: True
                row_default_height: sp(28)
        MDBoxLayout:
            id: boxbox
            size_hint: 1,.05
            DelButton:
                id: delbutton
                text:"Удалить маршрут"





