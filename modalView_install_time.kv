<MyModalView_install_time>:
    size_hint: (.5,.18)
    pos_hint: {"x": .01,"y": .77}
    MDBoxLayout:
        orientation: "vertical"
        Button_main:
            md_bg_color: "#B22222"
            on_release: root.weekday()
            Button_text:
                pos_hint: {"center_x": .5,"center_y": .5}
                bold: True
                text: "Будний день"
        Button_main:
            md_bg_color: "#1E90FF"
            on_release: root.weekend()
            Button_text:
                pos_hint: {"center_x": .5,"center_y": .5}
                text: "Выходной"
