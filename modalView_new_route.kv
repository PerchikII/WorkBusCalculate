<MyModalView_new_route>:
    size_hint: (.9,.1)
    pos_hint: {"x_center": 1,"y": .25}
    MDBoxLayout:
        Button_main:
            md_bg_color: "#B22222"
            on_release:
                root.weekday()
                root.dismiss()
            Button_text:
                pos_hint: {"center_x": .5,"center_y": .5}
                text: "Будний день"
        Button_main:
            md_bg_color: "#1E90FF"
            on_release:
                root.weekend()
                root.dismiss()
            Button_text:
                pos_hint: {"center_x": .5,"center_y": .5}
                text: "Выходной"