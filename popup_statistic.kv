<MyPopup_page_stat>:
    size_hint: (.9,.6)
    title: "Внимание!"
    halign: "center"
    title_size: sp(30)
    bold:True
    title_align: "center"
    # separator_color: "blue"
    MDScreen:
        md_bg_color: .8,.8,.8
        MDBoxLayout:
            id: root_stat_box
            orientation: "vertical"
            MDBoxLayout:
                orientation: "vertical"
                size_hint_y: .35
                padding: (0,dp(5),0,0)
                spacing: dp(5)
                MDBoxLayout:
                    size_hint_y: .15
                    TitleLabel:
                        text: f"За [color=#A52A2A]{root.title}[/color] введено: [size=20sp][color=#2E8B40]{root.quant_day}[/color][/size]   дней "
#                    TitleLabel:
#                        text: f"[size=20sp][color=#2E8B40]{root.quant_day}[/color][/size]   дней"
#                        halign: "left"
                MDBoxLayout:
                    orientation: "vertical"
                    size_hint_y: .4
                    MDBoxLayout:
                        size_hint_x: 1
                        #size_hint_y: .4
                        TitleLabel:
                            text: f"[size=20sp]Отработано:[/size]"
                    MDBoxLayout:
                        TitleLabel:
                            role: "large"
                            text: f"[color=#A52A2A]{root.tot_hours}[/color]  часов"
                        TitleLabel:
                            role: "large"
                            text: f"[color=#A52A2A]{root.tot_min}[/color]  минут"
            MDDivider:
                pos_hint: {'center_x': .5, 'center_y': .5}
                size_hint_x: .5
                theme_divider_color: "Custom"
                color: 0,0,0
                halign: "center"
            MDBoxLayout:
                orientation: "vertical"
                size_hint_y: .45
                padding: (dp(5),0,dp(5),0)
                MDBoxLayout:
                    TitleLabel:
                        text: f"[size=20sp][color=#00008B]{root.curr_date}[/color][/size]"
                MDBoxLayout:
                    #size_hint_y: .3
                    TitleLabel:
                        text: f"Введён маршрут :"
                MDBoxLayout:
                    #size_hint_y: .3
                    TitleLabel:
                        text: f" номер [size=20sp][color=#A52A2A]{root.route}[/color][/size]   карта [size=20sp][color=#A52A2A]{root.karta}[/color][/size]"

                MDBoxLayout:
                    #size_hint_y: .4
                    TitleLabel:
                        text: "Отработано:"
                MDBoxLayout:
                    #size_hint_y: .4
                    TitleLabel:
                        text: f"[size=20sp][color=#A52A2A]{root.karta_hours}[/color][/size]   часов   [size=20sp][color=#A52A2A]{root.karta_min}[/color][/size]   минут"

            MDBoxLayout:
                size_hint_y: .2
                Button_main:
                    on_release: root.dismiss()
                    color: 1,0,0,.1
                    Button_text:
                        pos_hint: {"center_x": .5,"center_y": .5}
                        text: "Закрыть"
                        halign: "center"
                        valign: "center"
                        text_color: 1,1,1













