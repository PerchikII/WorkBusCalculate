<Page_stat>:
    id: page_stat
    name: "stat_page"
    md_bg_color: app.theme_cls.primaryContainerColor # app.theme_cls.primaryColor # app.theme_cls.primaryContainerColor
    MDBoxLayout:
        id: root_stat_box
        orientation: "vertical"
        MDBoxLayout:
            padding: [sp(10),sp(10),sp(10),0]
            size_hint_y: .25
            TimeSpinner:
                id: spinner_day
                size_hint: .25, 1
                text: "27"# "root.day_spinner_str"
                values: map(str,list(range(1,32)))
                on_text: root.create_a_date_for_label()

            TimeSpinner:
                size_hint: .5, 1
                id: spinner_month
                font_size: 30
                text:  "Сентябрь"# "root.month_spinner_str"
                # values: root.spinner_month_lst
                on_text: root.create_a_date_for_label()

            TimeSpinner:
                id: spinner_day
                size_hint: .25, 1
                # pos_hint: {"top":1}
                text: "27"# "root.day_spinner_str"
                values: map(str,list(range(1,32)))
                on_text: root.create_a_date_for_label()
        MDBoxLayout:
            id: TwoBoxStat
            size_hint: 1, 1
            # md_bg_color: .1,1,.1
            padding: sp(10)
            MDCard:
                orientation: "vertical"
                size_hint: 1, 1
                # elevation: 20
                MDBoxLayout:
                    orientation: "vertical"
                    MDBoxLayout:
                        MDLabel:
                            text_size: self.size
                            theme_font_size: "Custom"
                            font_size: sp(20)
                            bold:True
                            text: spinner_month.text
#                                valign: "center"
#                                halign: "center"
                    MDBoxLayout:
                        MDLabel:
                            id: card_label_id
                            text_size: self.size
                            theme_font_size: "Custom"
                            font_size: sp(15)
                            bold:True
                            text:  "root.strig_statistic_for_label"


        MDBoxLayout:
            Button:
                text: "Кнопка"
        MDBoxLayout:
            size_hint_y: .5